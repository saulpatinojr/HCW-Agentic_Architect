<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WorkspaceManager.SettingsPage"
             BackgroundColor="#00000000">
    <ContentPage.Resources>
        <Color x:Key="AppBackground">#F3F6FA</Color>
        <Color x:Key="Surface">#FDFEFF</Color>
        <Color x:Key="SurfaceAlt">#F7F9FC</Color>
        <Color x:Key="Stroke">#D8E0EA</Color>
        <Color x:Key="StrokeStrong">#B9C7D6</Color>
        <Color x:Key="TextPrimary">#1B1F24</Color>
        <Color x:Key="TextSecondary">#4E5D6C</Color>
        <Color x:Key="TextMuted">#697887</Color>
        <Color x:Key="Accent">#0078D4</Color>
        <Color x:Key="Warning">#D83B01</Color>
    </ContentPage.Resources>

    <Grid Padding="24" BackgroundColor="#66000000">
        <Border WidthRequest="760"
                MaximumHeightRequest="720"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                BackgroundColor="{StaticResource Surface}"
                Stroke="{StaticResource Stroke}"
                StrokeThickness="1"
                Padding="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="10" />
            </Border.StrokeShape>
            <Grid RowDefinitions="Auto,*,Auto">
                <Grid Padding="18,16" ColumnDefinitions="*,Auto" ColumnSpacing="12" BackgroundColor="#F7F9FC">
                    <VerticalStackLayout Spacing="2">
                        <Label Text="Settings"
                               TextColor="{StaticResource TextPrimary}"
                               FontSize="22"
                               FontAttributes="Bold" />
                        <Label Text="Configure the local workspace manager, optional installs, and screen behavior."
                               TextColor="{StaticResource TextSecondary}"
                               FontSize="12" />
                    </VerticalStackLayout>
                    <Button Grid.Column="1"
                            Text="Close"
                            Clicked="OnCloseClicked"
                            BackgroundColor="{StaticResource Surface}"
                            BorderColor="{StaticResource StrokeStrong}"
                            BorderWidth="1"
                            TextColor="{StaticResource TextPrimary}"
                            Padding="14,7" />
                </Grid>

                <ScrollView Grid.Row="1">
                    <VerticalStackLayout Padding="18" Spacing="14">
                        <Border BackgroundColor="#F8FBFF" Stroke="#BFDDF5" Padding="12">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="4">
                                <Label Text="What this app changes"
                                       TextColor="{StaticResource TextPrimary}"
                                       FontSize="14"
                                       FontAttributes="Bold" />
                                <Label Text="AI Architect Agents scans local agent packs, validates required tools and files, previews workspace writes, updates packs from the catalog, and applies selected pack instructions into this repository. Preview mode keeps activation read-only until you are ready to apply."
                                       TextColor="{StaticResource TextSecondary}"
                                       FontSize="12"
                                       LineBreakMode="WordWrap" />
                            </VerticalStackLayout>
                        </Border>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <Border BackgroundColor="{StaticResource SurfaceAlt}" Stroke="{StaticResource Stroke}" Padding="12">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8" />
                                </Border.StrokeShape>
                                <VerticalStackLayout Spacing="10">
                                    <Label Text="Appearance"
                                           TextColor="{StaticResource TextPrimary}"
                                           FontSize="14"
                                           FontAttributes="Bold" />
                                    <Label Text="Theme" TextColor="{StaticResource TextSecondary}" FontSize="12" />
                                    <Picker x:Name="ThemePicker" SelectedIndex="0">
                                        <Picker.Items>
                                            <x:String>System</x:String>
                                            <x:String>Light</x:String>
                                            <x:String>Dark</x:String>
                                        </Picker.Items>
                                    </Picker>
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="4">
                                        <Switch x:Name="ShowHelperBalloonsSwitch"
                                                IsToggled="True"
                                                OnColor="{StaticResource Accent}"
                                                VerticalOptions="Start" />
                                        <VerticalStackLayout Grid.Column="1" Spacing="1">
                                            <Label Text="Show helper balloons" TextColor="{StaticResource TextPrimary}" FontSize="12" FontAttributes="Bold" />
                                            <Label Text="Keep explanatory callouts visible for new users."
                                                   TextColor="{StaticResource TextMuted}"
                                                   FontSize="11"
                                                   LineBreakMode="WordWrap"
                                                   MaxLines="2" />
                                        </VerticalStackLayout>
                                    </Grid>
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="4">
                                        <Switch x:Name="LockPanelSizingSwitch"
                                                IsToggled="False"
                                                OnColor="{StaticResource Accent}"
                                                VerticalOptions="Start" />
                                        <VerticalStackLayout Grid.Column="1" Spacing="1">
                                            <Label Text="Lock panel sizing" TextColor="{StaticResource TextPrimary}" FontSize="12" FontAttributes="Bold" />
                                            <Label Text="Keep panels fixed instead of stretching with the window."
                                                   TextColor="{StaticResource TextMuted}"
                                                   FontSize="11"
                                                   LineBreakMode="WordWrap"
                                                   MaxLines="2" />
                                        </VerticalStackLayout>
                                    </Grid>
                                </VerticalStackLayout>
                            </Border>

                            <Border Grid.Column="1" BackgroundColor="{StaticResource SurfaceAlt}" Stroke="{StaticResource Stroke}" Padding="12">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8" />
                                </Border.StrokeShape>
                                <VerticalStackLayout Spacing="10">
                                    <Label Text="Startup and safety"
                                           TextColor="{StaticResource TextPrimary}"
                                           FontSize="14"
                                           FontAttributes="Bold" />
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="4">
                                        <Switch x:Name="RunAtStartupSwitch"
                                                IsToggled="False"
                                                OnColor="{StaticResource Accent}"
                                                VerticalOptions="Start" />
                                        <VerticalStackLayout Grid.Column="1" Spacing="1">
                                            <Label Text="Run at startup" TextColor="{StaticResource TextPrimary}" FontSize="12" FontAttributes="Bold" />
                                            <Label Text="Open this control surface after Windows sign-in."
                                                   TextColor="{StaticResource TextMuted}"
                                                   FontSize="11"
                                                   LineBreakMode="WordWrap"
                                                   MaxLines="2" />
                                        </VerticalStackLayout>
                                    </Grid>
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="4">
                                        <Switch x:Name="ConfirmApplySwitch"
                                                IsToggled="True"
                                                OnColor="{StaticResource Accent}"
                                                VerticalOptions="Start" />
                                        <VerticalStackLayout Grid.Column="1" Spacing="1">
                                            <Label Text="Confirm before Apply" TextColor="{StaticResource TextPrimary}" FontSize="12" FontAttributes="Bold" />
                                            <Label Text="Ask before writing selected pack files."
                                                   TextColor="{StaticResource TextMuted}"
                                                   FontSize="11"
                                                   LineBreakMode="WordWrap"
                                                   MaxLines="2" />
                                        </VerticalStackLayout>
                                    </Grid>
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="4">
                                        <Switch x:Name="AutoCheckUpdatesSwitch"
                                                IsToggled="False"
                                                OnColor="{StaticResource Accent}"
                                                VerticalOptions="Start" />
                                        <VerticalStackLayout Grid.Column="1" Spacing="1">
                                            <Label Text="Check updates on scan" TextColor="{StaticResource TextPrimary}" FontSize="12" FontAttributes="Bold" />
                                            <Label Text="Refresh catalog state when packs are discovered."
                                                   TextColor="{StaticResource TextMuted}"
                                                   FontSize="11"
                                                   LineBreakMode="WordWrap"
                                                   MaxLines="2" />
                                        </VerticalStackLayout>
                                    </Grid>
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="4">
                                        <Switch x:Name="PreviewModeDefaultSwitch"
                                                IsToggled="True"
                                                OnColor="{StaticResource Accent}"
                                                VerticalOptions="Start" />
                                        <VerticalStackLayout Grid.Column="1" Spacing="1">
                                            <Label Text="Preview mode on Apply" TextColor="{StaticResource TextPrimary}" FontSize="12" FontAttributes="Bold" />
                                            <Label Text="Keep Apply in preview-only mode by default; no workspace files are written."
                                                   TextColor="{StaticResource TextMuted}"
                                                   FontSize="11"
                                                   LineBreakMode="WordWrap"
                                                   MaxLines="2" />
                                        </VerticalStackLayout>
                                    </Grid>
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="4">
                                        <Switch x:Name="EnableHelperMcpSwitch"
                                                IsToggled="True"
                                                OnColor="{StaticResource Accent}"
                                                VerticalOptions="Start" />
                                        <VerticalStackLayout Grid.Column="1" Spacing="1">
                                            <Label Text="Include Helper MCP" TextColor="{StaticResource TextPrimary}" FontSize="12" FontAttributes="Bold" />
                                            <Label Text="Use token-aware helper checks during scan, preflight, preview, and apply."
                                                   TextColor="{StaticResource TextMuted}"
                                                   FontSize="11"
                                                   LineBreakMode="WordWrap"
                                                   MaxLines="2" />
                                        </VerticalStackLayout>
                                    </Grid>
                                </VerticalStackLayout>
                            </Border>
                        </Grid>

                        <Border BackgroundColor="{StaticResource SurfaceAlt}" Stroke="{StaticResource Stroke}" Padding="12">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="10">
                                <Label Text="Optional downloads"
                                       TextColor="{StaticResource TextPrimary}"
                                       FontSize="14"
                                       FontAttributes="Bold" />
                                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                                    <Border Stroke="{StaticResource Stroke}" BackgroundColor="#FFFFFF" Padding="10">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="8" />
                                        </Border.StrokeShape>
                                        <VerticalStackLayout Spacing="4">
                                            <CheckBox x:Name="DashboardTrackCheckBox" IsChecked="True" />
                                            <Label Text="Dashboard" TextColor="{StaticResource TextPrimary}" FontSize="12" FontAttributes="Bold" />
                                            <Label Text="Built-in metrics and export views." TextColor="{StaticResource TextMuted}" FontSize="11" />
                                        </VerticalStackLayout>
                                    </Border>
                                    <Border Grid.Column="1" Stroke="{StaticResource Stroke}" BackgroundColor="#FFFFFF" Padding="10">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="8" />
                                        </Border.StrokeShape>
                                        <VerticalStackLayout Spacing="4">
                                            <CheckBox x:Name="SqliteTrackCheckBox" IsChecked="True" />
                                            <Label Text="SQLite trends" TextColor="{StaticResource TextPrimary}" FontSize="12" FontAttributes="Bold" />
                                            <Label Text="Local history store for trend charts." TextColor="{StaticResource TextMuted}" FontSize="11" />
                                        </VerticalStackLayout>
                                    </Border>
                                    <Border Grid.Column="2" Stroke="{StaticResource Stroke}" BackgroundColor="#FFFFFF" Padding="10">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="8" />
                                        </Border.StrokeShape>
                                        <VerticalStackLayout Spacing="4">
                                            <CheckBox x:Name="McpTrackCheckBox" IsChecked="True" />
                                            <Label Text="MCP runtime" TextColor="{StaticResource TextPrimary}" FontSize="12" FontAttributes="Bold" />
                                            <Label Text="Python helper for token-aware reads." TextColor="{StaticResource TextMuted}" FontSize="11" />
                                        </VerticalStackLayout>
                                    </Border>
                                </Grid>
                            </VerticalStackLayout>
                        </Border>

                        <Border BackgroundColor="#EEF4FF" Stroke="#BFDDF5" Padding="12">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="10">
                                <Label Text="Operating policies"
                                       TextColor="{StaticResource TextPrimary}"
                                       FontSize="14"
                                       FontAttributes="Bold" />
                                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="8">
                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="Security profile" TextColor="{StaticResource TextSecondary}" FontSize="12" FontAttributes="Bold" />
                                        <Picker x:Name="SecurityProfilePicker" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Column="1" Spacing="4">
                                        <Label Text="Workflow bundle" TextColor="{StaticResource TextSecondary}" FontSize="12" FontAttributes="Bold" />
                                        <Picker x:Name="WorkflowBundlePicker" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Row="1" Spacing="4">
                                        <Label Text="Delegation mode" TextColor="{StaticResource TextSecondary}" FontSize="12" FontAttributes="Bold" />
                                        <Picker x:Name="DelegationModePicker" />
                                    </VerticalStackLayout>
                                    <Grid Grid.Row="1" Grid.Column="1" ColumnDefinitions="Auto,*" ColumnSpacing="4">
                                        <Switch x:Name="StrictWorkflowModeSwitch" IsToggled="True" OnColor="{StaticResource Accent}" VerticalOptions="Start" />
                                        <VerticalStackLayout Grid.Column="1" Spacing="1">
                                            <Label Text="Strict workflow mode" TextColor="{StaticResource TextPrimary}" FontSize="12" FontAttributes="Bold" />
                                            <Label Text="Block Apply when checkpoints or quality gates fail." TextColor="{StaticResource TextMuted}" FontSize="11" LineBreakMode="WordWrap" MaxLines="2" />
                                        </VerticalStackLayout>
                                    </Grid>
                                    <VerticalStackLayout Grid.Row="2" Spacing="4">
                                        <Label Text="Research min" TextColor="{StaticResource TextSecondary}" FontSize="12" FontAttributes="Bold" />
                                        <Entry x:Name="ResearchScoreMinEntry" Keyboard="Numeric" Text="70" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Row="2" Grid.Column="1" Spacing="4">
                                        <Label Text="Plan min" TextColor="{StaticResource TextSecondary}" FontSize="12" FontAttributes="Bold" />
                                        <Entry x:Name="PlanScoreMinEntry" Keyboard="Numeric" Text="75" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Row="3" Spacing="4">
                                        <Label Text="Max auto retry" TextColor="{StaticResource TextSecondary}" FontSize="12" FontAttributes="Bold" />
                                        <Entry x:Name="MaxAutoRetryEntry" Keyboard="Numeric" Text="2" />
                                    </VerticalStackLayout>
                                    <Grid Grid.Row="3" Grid.Column="1" ColumnDefinitions="Auto,*" ColumnSpacing="4">
                                        <Switch x:Name="TestPassRequiredSwitch" IsToggled="True" OnColor="{StaticResource Accent}" VerticalOptions="Start" />
                                        <VerticalStackLayout Grid.Column="1" Spacing="1">
                                            <Label Text="Test pass required" TextColor="{StaticResource TextPrimary}" FontSize="12" FontAttributes="Bold" />
                                            <Label Text="Block apply if packs fail validation." TextColor="{StaticResource TextMuted}" FontSize="11" LineBreakMode="WordWrap" MaxLines="2" />
                                        </VerticalStackLayout>
                                    </Grid>
                                </Grid>
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="Bypass reason" TextColor="{StaticResource TextSecondary}" FontSize="12" FontAttributes="Bold" />
                                    <Entry x:Name="BypassReasonEntry" Placeholder="Required when strict mode is off" />
                                </VerticalStackLayout>
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="Delegation profiles JSON" TextColor="{StaticResource TextSecondary}" FontSize="12" FontAttributes="Bold" />
                                    <Editor x:Name="DelegationProfilesEditor" AutoSize="TextChanges" HeightRequest="150" />
                                </VerticalStackLayout>
                                <HorizontalStackLayout Spacing="8" HorizontalOptions="End">
                                    <Button Text="Save local variant" Clicked="OnSavePolicyVariantClicked" BackgroundColor="#FFFFFF" BorderColor="#A8C4E8" BorderWidth="1" TextColor="#005A9E" Padding="12,6" />
                                </HorizontalStackLayout>
                                <Label x:Name="PolicyStatusLabel" Text="Policy manifests are stored locally per Windows profile." TextColor="{StaticResource TextMuted}" FontSize="11" LineBreakMode="WordWrap" />
                            </VerticalStackLayout>
                        </Border>

                        <Border BackgroundColor="#F1F7FF" Stroke="#BFDDF5" Padding="12">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="10">
                                <Label Text="Harness policy scopes" TextColor="{StaticResource TextPrimary}" FontSize="14" FontAttributes="Bold" />
                                <Label Text="Edit the JSON manifest that controls global, pack, and session overrides for the harness adapters." TextColor="{StaticResource TextSecondary}" FontSize="11" LineBreakMode="WordWrap" />
                                <Editor x:Name="HarnessPolicyEditor" AutoSize="TextChanges" HeightRequest="150" />
                                <HorizontalStackLayout Spacing="8" HorizontalOptions="End">
                                    <Button Text="Save harness policy" Clicked="OnSaveHarnessPolicyClicked" BackgroundColor="#FFFFFF" BorderColor="#A8C4E8" BorderWidth="1" TextColor="#005A9E" Padding="12,6" />
                                </HorizontalStackLayout>
                                <Label x:Name="HarnessPolicyStatusLabel" Text="Harness policy manifest is stored locally per Windows profile." TextColor="{StaticResource TextMuted}" FontSize="11" LineBreakMode="WordWrap" />
                            </VerticalStackLayout>
                        </Border>

                        <Border BackgroundColor="#FFF8E8" Stroke="#E7C27B" Padding="12">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="10">
                                <Label Text="Maintenance"
                                       TextColor="#7A4F01"
                                       FontSize="14"
                                       FontAttributes="Bold" />
                                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                                    <Button Text="Manual backup"
                                            Clicked="OnManualBackupClicked"
                                            BackgroundColor="#FFFFFF"
                                            BorderColor="#DAB47A"
                                            BorderWidth="1"
                                            TextColor="#805C1A"
                                            Padding="10,7" />
                                    <Button Grid.Column="1"
                                            Text="Reset configuration"
                                            Clicked="OnResetClicked"
                                            BackgroundColor="#FFFFFF"
                                            BorderColor="#DAB47A"
                                            BorderWidth="1"
                                            TextColor="#805C1A"
                                            Padding="10,7" />
                                    <Button Grid.Column="2"
                                            Text="Open data folder"
                                            Clicked="OnOpenDataFolderClicked"
                                            BackgroundColor="#FFFFFF"
                                            BorderColor="#DAB47A"
                                            BorderWidth="1"
                                            TextColor="#805C1A"
                                            Padding="10,7" />
                                </Grid>
                                <Label x:Name="SettingsStatusLabel"
                                       Text="Preferences are local to this Windows profile."
                                       TextColor="#805C1A"
                                       FontSize="11" />
                            </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>
                </ScrollView>

                <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Padding="18,14" BackgroundColor="#F7F9FC">
                    <Label Text="More settings can be wired here as the app grows."
                           TextColor="{StaticResource TextMuted}"
                           FontSize="11"
                           VerticalOptions="Center" />
                    <Button Grid.Column="1"
                            Text="Save"
                            Clicked="OnSaveClicked"
                            BackgroundColor="{StaticResource Accent}"
                            TextColor="White"
                            FontAttributes="Bold"
                            Padding="18,8" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</ContentPage>
