<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WorkspaceManager.MainPage"
             BackgroundColor="#F3F6FA"
             SizeChanged="OnPageSizeChanged">
    <ContentPage.Resources>
        <Color x:Key="AppBackground">#F3F6FA</Color>
        <Color x:Key="Surface">#FDFEFF</Color>
        <Color x:Key="SurfaceAlt">#F7F9FC</Color>
        <Color x:Key="Stroke">#D8E0EA</Color>
        <Color x:Key="StrokeStrong">#B9C7D6</Color>
        <Color x:Key="TextPrimary">#1B1F24</Color>
        <Color x:Key="TextSecondary">#4E5D6C</Color>
        <Color x:Key="TextMuted">#697887</Color>
        <Color x:Key="Accent">#0078D4</Color>
        <Color x:Key="AccentHover">#106EBE</Color>
        <Color x:Key="Success">#107C10</Color>
        <Color x:Key="Warning">#D83B01</Color>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*" Padding="20" RowSpacing="12">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#F7FAFD" Offset="0" />
                <GradientStop Color="#EEF4FA" Offset="0.62" />
                <GradientStop Color="#F8FAFC" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
            <Border BackgroundColor="{StaticResource Accent}"
                    Stroke="#005A9E"
                    StrokeThickness="1"
                    WidthRequest="56"
                    HeightRequest="56"
                    Padding="5">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>
                <Image Source="ai_architect_agents.png" WidthRequest="46" HeightRequest="46" />
            </Border>

            <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                <Label Text="AI Architect Agents"
                       TextColor="{StaticResource TextPrimary}"
                       FontFamily="Segoe UI Variable"
                       FontSize="25"
                       FontAttributes="Bold" />
                <Label Text="Compose, validate, update, and activate local AI architecture agent packs."
                       TextColor="{StaticResource TextSecondary}"
                       FontSize="13"
                       LineBreakMode="TailTruncation" />
            </VerticalStackLayout>

            <Border Grid.Column="2"
                    BackgroundColor="#CCFFFFFF"
                    Stroke="{StaticResource Stroke}"
                    StrokeThickness="1"
                    Padding="6,5"
                    MinimumWidthRequest="200">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6">
                    <Button Text="⚙"
                            Clicked="OnOpenSettingsClicked"
                            ToolTipProperties.Text="Open settings and preferences"
                            BackgroundColor="#FFF7D6"
                            BorderColor="#E7C27B"
                            BorderWidth="1"
                            TextColor="#805C1A"
                            FontSize="16"
                            WidthRequest="34"
                            HeightRequest="34"
                            Padding="0" />
                    <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                        <HorizontalStackLayout Spacing="5" VerticalOptions="Center">
                            <Border x:Name="StatusIndicatorDot"
                                    WidthRequest="9"
                                    HeightRequest="9"
                                    BackgroundColor="#0078D4"
                                    StrokeThickness="0"
                                    VerticalOptions="Center">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="999" />
                                </Border.StrokeShape>
                            </Border>
                            <Label x:Name="StatusLabel"
                                   Text="Ready"
                                   TextColor="{StaticResource TextPrimary}"
                                   FontSize="10"
                                   FontAttributes="Bold"
                                   ToolTipProperties.Text="Status colors: Blue=ready, Green=loading, Yellow=configuring/downloading, Red=configuration issue" />
                        </HorizontalStackLayout>
                        <Label x:Name="LastScanLabel"
                               Text="Last update: not run yet"
                               TextColor="{StaticResource TextMuted}"
                               FontSize="10" />
                    </VerticalStackLayout>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="1"
                Stroke="{StaticResource Stroke}"
                StrokeThickness="1"
                BackgroundColor="#CCFFFFFF"
                Padding="8,8,8,6">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="10" />
            </Border.StrokeShape>
            <FlexLayout Wrap="Wrap" AlignItems="Center" JustifyContent="Center">
                <Button Text="Scan"
                        Clicked="OnScanWorkspaceClicked"
                        ToolTipProperties.Text="Discover local workspace packs"
                        BackgroundColor="#EAF1F8"
                        BorderColor="{StaticResource StrokeStrong}"
                        BorderWidth="1"
                        TextColor="{StaticResource TextPrimary}"
                        Padding="12,7"
                        Margin="0,0,5,6" />
                <Button Text="Import"
                        Clicked="OnImportWorkspacePackClicked"
                        ToolTipProperties.Text="Import a zipped workspace pack"
                    BackgroundColor="#EAF1F8"
                        BorderColor="{StaticResource StrokeStrong}"
                        BorderWidth="1"
                        TextColor="{StaticResource TextPrimary}"
                        Padding="12,7"
                        Margin="0,0,5,6" />
                <Button Text="Preflight"
                        Clicked="OnSystemCheckClicked"
                        ToolTipProperties.Text="Validate tools, MCP paths, and required files"
                    BackgroundColor="#EAF1F8"
                        BorderColor="{StaticResource StrokeStrong}"
                        BorderWidth="1"
                        TextColor="{StaticResource TextPrimary}"
                        Padding="12,7"
                        Margin="0,0,5,6" />
                <Button Text="Preview"
                        Clicked="OnPreviewWorkspaceClicked"
                        ToolTipProperties.Text="Run activation without writing files"
                    BackgroundColor="#EAF1F8"
                        BorderColor="{StaticResource StrokeStrong}"
                        BorderWidth="1"
                        TextColor="{StaticResource TextPrimary}"
                        Padding="12,7"
                        Margin="0,0,5,6" />
                <Button Text="Check updates"
                        Clicked="OnCheckUpdatesClicked"
                        ToolTipProperties.Text="Compare local packs with the catalog"
                    BackgroundColor="#EAF1F8"
                        BorderColor="{StaticResource StrokeStrong}"
                        BorderWidth="1"
                        TextColor="{StaticResource TextPrimary}"
                        Padding="12,7"
                        Margin="0,0,5,6" />
                <Button x:Name="UpdateButton"
                        Text="Update pack"
                        Clicked="OnUpdateSelectedPackClicked"
                        ToolTipProperties.Text="Download and replace the selected pack from the repository"
                    BackgroundColor="#EAF1F8"
                        BorderColor="{StaticResource StrokeStrong}"
                        BorderWidth="1"
                        TextColor="{StaticResource TextPrimary}"
                        Padding="12,7"
                        Margin="0,0,5,6" />
                <Button x:Name="ApplyButton"
                        Text="Apply"
                        Clicked="OnActivateWorkspaceClicked"
                        ToolTipProperties.Text="Write selected pack files to the workspace"
                        BackgroundColor="{StaticResource Accent}"
                        TextColor="White"
                        FontAttributes="Bold"
                        Padding="14,7"
                        Margin="0,0,8,6" />

                <Border BackgroundColor="#F8FBFF" Stroke="#BFDDF5" Padding="9,6" Margin="2,0,0,6">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <Label Text="Flow: Scan finds packs, Preflight checks missing tools, Preview shows file changes, Apply writes selected packs."
                           TextColor="{StaticResource TextSecondary}"
                           FontSize="11"
                           MaximumWidthRequest="390"
                           LineBreakMode="WordWrap" />
                </Border>
            </FlexLayout>
        </Border>

        <Border x:Name="OptionalSetupBanner"
                Grid.Row="2"
                IsVisible="False"
                Stroke="#E7C27B"
                StrokeThickness="1"
                BackgroundColor="#FFF8E8"
                Padding="12">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="10" />
            </Border.StrokeShape>
            <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="8" ColumnSpacing="10">
                <VerticalStackLayout Spacing="2">
                    <Label Text="Optional feature tracks"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="#7A4F01" />
                    <Label Text="Install tracks once, skip already-installed items automatically, and optionally never ask again."
                           FontSize="11"
                           TextColor="#805C1A" />
                </VerticalStackLayout>
                <Border Grid.Column="1" BackgroundColor="#FFF1D6" Stroke="#E7C27B" Padding="8,4">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="999" />
                    </Border.StrokeShape>
                    <Label Text="Startup Setup"
                           FontSize="10"
                           TextColor="#7A4F01"
                           FontAttributes="Bold" />
                </Border>

                <Grid Grid.Row="1" Grid.ColumnSpan="2" ColumnDefinitions="*,*,*" ColumnSpacing="10">
                    <Border Stroke="#E7C27B" BackgroundColor="#FFFDF5" Padding="8">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="4">
                            <HorizontalStackLayout Spacing="8">
                                <CheckBox x:Name="DashboardTrackCheckBox" IsChecked="True" />
                                <Label Text="Dashboard" FontSize="11" TextColor="#6B4A14" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                            <Label x:Name="DashboardTrackStatusLabel" Text="Bundled in app build" FontSize="10" TextColor="#8A6A2E" />
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="1" Stroke="#E7C27B" BackgroundColor="#FFFDF5" Padding="8">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="4">
                            <HorizontalStackLayout Spacing="8">
                                <CheckBox x:Name="SqliteTrackCheckBox" IsChecked="True" />
                                <Label Text="SQLite trends" FontSize="11" TextColor="#6B4A14" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                            <Label x:Name="SqliteTrackStatusLabel" Text="Bundled in app build" FontSize="10" TextColor="#8A6A2E" />
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="2" Stroke="#E7C27B" BackgroundColor="#FFFDF5" Padding="8">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="4">
                            <HorizontalStackLayout Spacing="8">
                                <CheckBox x:Name="McpTrackCheckBox" IsChecked="True" />
                                <Label Text="MCP runtime" FontSize="11" TextColor="#6B4A14" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                            <Label x:Name="McpTrackStatusLabel" Text="Checking Python dependencies..." FontSize="10" TextColor="#8A6A2E" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <Grid Grid.Row="2" Grid.ColumnSpan="2" ColumnDefinitions="*,Auto" ColumnSpacing="10">
                    <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                        <CheckBox x:Name="NeverAskAgainCheckBox" IsChecked="False" />
                        <Label Text="Never ask again" FontSize="11" TextColor="#6B4A14" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Grid.Column="1" Spacing="8" HorizontalOptions="End">
                        <Button Text="Skip"
                                Clicked="OnSkipOptionalTracksClicked"
                                BackgroundColor="#FFFFFF"
                                BorderColor="#DAB47A"
                                BorderWidth="1"
                                TextColor="#805C1A"
                                Padding="12,6" />
                        <Button Text="Install selected"
                                Clicked="OnInstallOptionalTracksClicked"
                                BackgroundColor="#A86F00"
                                TextColor="White"
                                Padding="12,6" />
                    </HorizontalStackLayout>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="3"
                Stroke="{StaticResource Stroke}"
                StrokeThickness="1"
                BackgroundColor="{StaticResource Surface}"
                Padding="10">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="10" />
            </Border.StrokeShape>
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                <HorizontalStackLayout Spacing="16">
                    <VerticalStackLayout Spacing="1">
                        <Label Text="Context optimization" TextColor="{StaticResource TextPrimary}" FontSize="12" FontAttributes="Bold" />
                        <Label x:Name="DashboardPreviewSavedLabel" Text="Tokens saved: 0" TextColor="{StaticResource TextSecondary}" FontSize="11" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Spacing="1">
                        <Label Text="Efficiency" TextColor="{StaticResource TextPrimary}" FontSize="12" FontAttributes="Bold" />
                        <Label x:Name="DashboardPreviewEfficiencyLabel" Text="Compression: 0%" TextColor="{StaticResource TextSecondary}" FontSize="11" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Spacing="1">
                        <Label Text="Partner leader" TextColor="{StaticResource TextPrimary}" FontSize="12" FontAttributes="Bold" />
                        <Label x:Name="DashboardPreviewPartnerLabel" Text="Top: n/a" TextColor="{StaticResource TextSecondary}" FontSize="11" />
                    </VerticalStackLayout>
                </HorizontalStackLayout>
                <HorizontalStackLayout Grid.Column="1" Spacing="8" HorizontalOptions="End">
                    <Button Text="Refresh dashboard" Clicked="OnRefreshDashboardClicked" Padding="12,6" />
                    <Button Text="Open dashboard" Clicked="OnOpenDashboardClicked" Padding="12,6" />
                    <Button Text="Detach" Clicked="OnDetachDashboardClicked" Padding="12,6" />
                </HorizontalStackLayout>
            </Grid>
        </Border>

        <Grid Grid.Row="4" RowDefinitions="Auto,*" RowSpacing="12">
                <Border Stroke="{StaticResource Stroke}" StrokeThickness="1" BackgroundColor="{StaticResource Surface}" Padding="10">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10" />
                    </Border.StrokeShape>
                    <Label x:Name="WorkspacePathLabel"
                           Text="Workspace: resolving..."
                           TextColor="{StaticResource TextSecondary}"
                           FontSize="12"
                           LineBreakMode="TailTruncation" />
                </Border>

                <Grid x:Name="MainContentGrid"
                      Grid.Row="1"
                      ColumnDefinitions="300,*,330"
                      RowDefinitions="*"
                      ColumnSpacing="12"
                      RowSpacing="12">
                    <Grid x:Name="LeftRail" Grid.Column="0" RowDefinitions="Auto,*" RowSpacing="12">
                        <Border Stroke="{StaticResource Stroke}" StrokeThickness="1" BackgroundColor="{StaticResource Surface}" Padding="14">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="12">
                                <Label Text="Run state" TextColor="{StaticResource TextPrimary}" FontSize="16" FontAttributes="Bold" />
                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="9">
                                    <Label Text="Discovered" TextColor="{StaticResource TextSecondary}" FontSize="12" />
                                    <Label x:Name="PackCountLabel" Grid.Column="1" Text="0" TextColor="{StaticResource TextPrimary}" FontSize="15" FontAttributes="Bold" />
                                    <Label Grid.Row="1" Text="Selected" TextColor="{StaticResource TextSecondary}" FontSize="12" />
                                    <Label x:Name="SelectionCountLabel" Grid.Row="1" Grid.Column="1" Text="0" TextColor="{StaticResource TextPrimary}" FontSize="15" FontAttributes="Bold" />
                                    <Label Grid.Row="2" Text="Missing" TextColor="{StaticResource TextSecondary}" FontSize="12" />
                                    <Label x:Name="MissingRequirementsLabel" Grid.Row="2" Grid.Column="1" Text="-" TextColor="{StaticResource Warning}" FontSize="15" FontAttributes="Bold" />
                                    <Label Grid.Row="3" Text="MCP" TextColor="{StaticResource TextSecondary}" FontSize="12" />
                                    <Label x:Name="McpHealthLabel" Grid.Row="3" Grid.Column="1" Text="Checking" TextColor="{StaticResource Accent}" FontSize="12" FontAttributes="Bold" />
                                </Grid>
                                <Label x:Name="McpSummaryLabel"
                                       Text="Helper status pending."
                                       TextColor="{StaticResource TextMuted}"
                                       FontSize="11"
                                       LineBreakMode="WordWrap" />
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Row="1" Stroke="{StaticResource Stroke}" StrokeThickness="1" BackgroundColor="{StaticResource Surface}" Padding="14">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10" />
                            </Border.StrokeShape>
                            <Grid RowDefinitions="Auto,*" RowSpacing="12">
                                <Label Text="Providers" TextColor="{StaticResource TextPrimary}" FontSize="16" FontAttributes="Bold" />
                                <CollectionView x:Name="ProvidersCollectionView"
                                                Grid.Row="1"
                                                SelectionMode="None">
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate>
                                            <VerticalStackLayout Spacing="8" Margin="0,0,0,12">
                                                <Label Text="{Binding Name}" TextColor="{StaticResource TextSecondary}" FontSize="12" FontAttributes="Bold" />
                                                <CollectionView ItemsSource="{Binding Providers}" SelectionMode="Single" SelectionChanged="OnProviderSelected">
                                                    <CollectionView.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Stroke="{StaticResource Stroke}" StrokeThickness="1" BackgroundColor="{StaticResource SurfaceAlt}" Padding="8" Margin="0,0,0,6">
                                                                <Border.StrokeShape>
                                                                    <RoundRectangle CornerRadius="8" />
                                                                </Border.StrokeShape>
                                                                <Grid ColumnDefinitions="48,*" ColumnSpacing="9">
                                                                    <Border BackgroundColor="#FFFFFF" Stroke="{StaticResource Stroke}" StrokeThickness="1" WidthRequest="42" HeightRequest="30" Padding="3">
                                                                        <Border.StrokeShape>
                                                                            <RoundRectangle CornerRadius="7" />
                                                                        </Border.StrokeShape>
                                                                        <Image Source="{Binding IconAsset}" WidthRequest="36" HeightRequest="24" Aspect="AspectFit" />
                                                                    </Border>
                                                                    <VerticalStackLayout Grid.Column="1" Spacing="1">
                                                                        <Label Text="{Binding Name}" TextColor="{StaticResource TextPrimary}" FontSize="12" FontAttributes="Bold" />
                                                                        <Label Text="{Binding OfficialUrl}" TextColor="{StaticResource TextMuted}" FontSize="10" LineBreakMode="TailTruncation" />
                                                                    </VerticalStackLayout>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </CollectionView.ItemTemplate>
                                                </CollectionView>
                                            </VerticalStackLayout>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid x:Name="CenterPanel" Grid.Column="1" RowDefinitions="*,*" RowSpacing="12">
                        <Border Stroke="{StaticResource Stroke}" StrokeThickness="1" BackgroundColor="{StaticResource Surface}" Padding="14">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10" />
                            </Border.StrokeShape>
                            <Grid RowDefinitions="Auto,Auto,*" RowSpacing="10">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="Workspace packs" TextColor="{StaticResource TextPrimary}" FontSize="17" FontAttributes="Bold" />
                                        <Label Text="Select a pack to inspect requirements, providers, files, and update state." TextColor="{StaticResource TextSecondary}" FontSize="12" />
                                    </VerticalStackLayout>
                                    <Label Grid.Column="1" Text="Details" TextColor="{StaticResource Accent}" FontSize="11" VerticalOptions="End" />
                                </Grid>

                                <Border Grid.Row="1" BackgroundColor="#F8FBFF" Stroke="#BFDDF5" Padding="10">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="8" />
                                    </Border.StrokeShape>
                                    <Label Text="Start here: Scan finds packs in this repository, then select one to see what tools, files, providers, and links it controls. Use Preview before Apply to see planned writes without changing files."
                                           TextColor="{StaticResource TextSecondary}"
                                           FontSize="11"
                                           LineBreakMode="WordWrap" />
                                </Border>

                                <CollectionView x:Name="AgentsCollectionView"
                                                Grid.Row="2"
                                                VerticalScrollBarVisibility="Always"
                                                SelectionMode="Single"
                                                SelectionChanged="OnPackSelectionChanged">
                                    <CollectionView.EmptyView>
                                        <VerticalStackLayout Padding="30" Spacing="8" HorizontalOptions="Center" VerticalOptions="Center">
                                            <Label Text="No packs found" TextColor="{StaticResource TextPrimary}" FontAttributes="Bold" FontSize="15" HorizontalOptions="Center" />
                                            <Label Text="Scan the workspace or import a pack to populate this list." TextColor="{StaticResource TextSecondary}" FontSize="12" HorizontalOptions="Center" />
                                        </VerticalStackLayout>
                                    </CollectionView.EmptyView>
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate>
                                            <Border Stroke="{StaticResource Stroke}" StrokeThickness="1" BackgroundColor="{StaticResource SurfaceAlt}" Padding="10" Margin="0,0,0,8">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="8" />
                                                </Border.StrokeShape>
                                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                                    <CheckBox IsChecked="{Binding IsSelected}" Color="{StaticResource Accent}" CheckedChanged="OnAgentCheckedChanged" VerticalOptions="Start" />
                                                    <VerticalStackLayout Grid.Column="1" Spacing="3">
                                                        <HorizontalStackLayout Spacing="8">
                                                            <Label Text="{Binding FriendlyName}" TextColor="{StaticResource TextPrimary}" FontSize="14" FontAttributes="Bold" />
                                                            <Border BackgroundColor="#EAF4FD" Stroke="#A8D4F2" Padding="7,2">
                                                                <Border.StrokeShape>
                                                                    <RoundRectangle CornerRadius="999" />
                                                                </Border.StrokeShape>
                                                                <Label Text="{Binding Version}" TextColor="#005A9E" FontSize="10" />
                                                            </Border>
                                                        </HorizontalStackLayout>
                                                        <Label Text="{Binding Description}" TextColor="{StaticResource TextSecondary}" FontSize="12" LineBreakMode="WordWrap" MaxLines="2" />
                                                        <Label Text="{Binding FullPath}" TextColor="{StaticResource TextMuted}" FontSize="10" LineBreakMode="TailTruncation" />
                                                    </VerticalStackLayout>
                                                    <VerticalStackLayout Grid.Column="2" Spacing="5" HorizontalOptions="End">
                                                        <Label Text="{Binding Category}" TextColor="{StaticResource TextSecondary}" FontSize="11" HorizontalOptions="End" />
                                                        <Label Text="{Binding UpdateState}" TextColor="{StaticResource Accent}" FontSize="11" FontAttributes="Bold" HorizontalOptions="End" />
                                                    </VerticalStackLayout>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1" Stroke="{StaticResource Stroke}" StrokeThickness="1" BackgroundColor="{StaticResource Surface}" Padding="14">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10" />
                            </Border.StrokeShape>
                            <Grid RowDefinitions="Auto,Auto,*" RowSpacing="10">
                                <Label Text="Activity" TextColor="{StaticResource TextPrimary}" FontSize="17" FontAttributes="Bold" />
                                <Border Grid.Row="1" BackgroundColor="#F8FBFF" Stroke="#BFDDF5" Padding="10">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="8" />
                                    </Border.StrokeShape>
                                    <Label Text="Activity is the audit trail. It records scan results, missing requirements, preview output, update attempts, applied changes, and errors so a new user can see what happened and why."
                                           TextColor="{StaticResource TextSecondary}"
                                           FontSize="11"
                                           LineBreakMode="WordWrap" />
                                </Border>
                                <CollectionView x:Name="ActivityCollectionView" Grid.Row="2" VerticalScrollBarVisibility="Always" SelectionMode="None">
                                    <CollectionView.EmptyView>
                                        <Label Text="Activity appears here after scan, preflight, preview, update, or apply." TextColor="{StaticResource TextSecondary}" FontSize="12" HorizontalOptions="Center" VerticalOptions="Center" />
                                    </CollectionView.EmptyView>
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate>
                                            <Border Stroke="{StaticResource Stroke}" StrokeThickness="1" BackgroundColor="{StaticResource SurfaceAlt}" Padding="9" Margin="0,0,0,6">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="8" />
                                                </Border.StrokeShape>
                                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                                    <Label Text="{Binding SeverityGlyph}" TextColor="{Binding AccentColor}" FontSize="10" FontAttributes="Bold" VerticalOptions="Start" />
                                                    <VerticalStackLayout Grid.Column="1" Spacing="2">
                                                        <Label Text="{Binding Message}" TextColor="{StaticResource TextPrimary}" FontSize="12" LineBreakMode="WordWrap" />
                                                        <Label Text="{Binding Detail}" TextColor="{StaticResource TextMuted}" FontSize="10" LineBreakMode="TailTruncation" />
                                                    </VerticalStackLayout>
                                                    <VerticalStackLayout Grid.Column="2" Spacing="2" HorizontalOptions="End">
                                                        <Label Text="{Binding Category}" TextColor="{StaticResource Accent}" FontSize="10" HorizontalOptions="End" />
                                                        <Label Text="{Binding DisplayTime}" TextColor="{StaticResource TextMuted}" FontSize="10" HorizontalOptions="End" />
                                                    </VerticalStackLayout>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid x:Name="InspectorPanel" Grid.Column="2" RowDefinitions="*,300" RowSpacing="12">
                        <Border Stroke="{StaticResource Stroke}" StrokeThickness="1" BackgroundColor="{StaticResource Surface}" Padding="14">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="10">
                                <Label Text="Pack inspector" TextColor="{StaticResource TextPrimary}" FontSize="17" FontAttributes="Bold" />
                                <Label x:Name="SelectedPackNameLabel" Text="Select a pack" TextColor="{StaticResource TextPrimary}" FontSize="14" FontAttributes="Bold" />
                                <Label x:Name="SelectedPackDescriptionLabel" Text="Pack metadata, dimension status, provider links, files, and MCP requirements appear here." TextColor="{StaticResource TextSecondary}" FontSize="12" LineBreakMode="WordWrap" />

                                <Border BackgroundColor="#F8FBFF" Stroke="#BFDDF5" Padding="10">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="8" />
                                    </Border.StrokeShape>
                                    <VerticalStackLayout Spacing="6">
                                        <Label x:Name="DimensionsSummaryLabel" Text="Dimensions: select a pack to inspect WHO/HOW/TRUST/TALK coverage." TextColor="{StaticResource TextPrimary}" FontSize="11" FontAttributes="Bold" />
                                        <Label x:Name="WhoDimensionLabel" Text="WHO: not loaded" TextColor="{StaticResource TextSecondary}" FontSize="11" LineBreakMode="WordWrap" />
                                        <Label x:Name="WhoDetailsLabel" Text="Responsibilities: not loaded" TextColor="{StaticResource TextMuted}" FontSize="10" LineBreakMode="WordWrap" />
                                        <Label x:Name="HowDimensionLabel" Text="HOW: not loaded" TextColor="{StaticResource TextSecondary}" FontSize="11" LineBreakMode="WordWrap" />
                                        <Label x:Name="HowDetailsLabel" Text="Handoffs: not loaded" TextColor="{StaticResource TextMuted}" FontSize="10" LineBreakMode="WordWrap" />
                                        <Label x:Name="TrustDimensionLabel" Text="TRUST: not loaded" TextColor="{StaticResource TextSecondary}" FontSize="11" LineBreakMode="WordWrap" />
                                        <Label x:Name="TrustDetailsLabel" Text="Guardrails: not loaded" TextColor="{StaticResource TextMuted}" FontSize="10" LineBreakMode="WordWrap" />
                                        <Label x:Name="TalkDimensionLabel" Text="TALK: not loaded" TextColor="{StaticResource TextSecondary}" FontSize="11" LineBreakMode="WordWrap" />
                                        <Label x:Name="TalkDetailsLabel" Text="Channels: not loaded" TextColor="{StaticResource TextMuted}" FontSize="10" LineBreakMode="WordWrap" />
                                    </VerticalStackLayout>
                                </Border>

                                <Label Text="Provider links" TextColor="{StaticResource TextSecondary}" FontSize="12" FontAttributes="Bold" />
                                <CollectionView x:Name="SelectedProvidersCollectionView"
                                                HeightRequest="64"
                                                SelectionMode="Single"
                                                SelectionChanged="OnProviderSelected"
                                                ItemsLayout="HorizontalList">
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate>
                                            <Border Stroke="{StaticResource Stroke}" StrokeThickness="1" BackgroundColor="{StaticResource SurfaceAlt}" Padding="7" Margin="0,0,8,0">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="8" />
                                                </Border.StrokeShape>
                                                <HorizontalStackLayout Spacing="6">
                                                    <Image Source="{Binding IconAsset}" WidthRequest="22" HeightRequest="22" />
                                                    <Label Text="{Binding Name}" TextColor="{StaticResource TextPrimary}" FontSize="11" VerticalOptions="Center" />
                                                </HorizontalStackLayout>
                                            </Border>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>

                                <Label Text="Guidance links" TextColor="{StaticResource TextSecondary}" FontSize="12" FontAttributes="Bold" />
                                <CollectionView x:Name="PackLinksCollectionView" HeightRequest="78" SelectionMode="None">
                                    <CollectionView.EmptyView>
                                        <Label Text="No links declared." TextColor="{StaticResource TextMuted}" FontSize="11" />
                                    </CollectionView.EmptyView>
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate>
                                            <Button Text="{Binding Label}"
                                                    Clicked="OnPackLinkClicked"
                                                    CommandParameter="{Binding Url}"
                                                    BackgroundColor="{StaticResource SurfaceAlt}"
                                                    BorderColor="{StaticResource StrokeStrong}"
                                                    BorderWidth="1"
                                                    TextColor="{StaticResource Accent}"
                                                    FontSize="11"
                                                    Padding="8,5"
                                                    Margin="0,0,0,6" />
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>

                                <Label Text="Required tools" TextColor="{StaticResource TextSecondary}" FontSize="12" FontAttributes="Bold" />
                                <CollectionView x:Name="RequiredToolsCollectionView" HeightRequest="76" SelectionMode="None">
                                    <CollectionView.EmptyView>
                                        <Label Text="No required tools declared." TextColor="{StaticResource TextMuted}" FontSize="11" />
                                    </CollectionView.EmptyView>
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate>
                                            <Label Text="{Binding DisplayName}" TextColor="{StaticResource TextSecondary}" FontSize="11" />
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>

                                <Label Text="MCP servers" TextColor="{StaticResource TextSecondary}" FontSize="12" FontAttributes="Bold" />
                                <CollectionView x:Name="McpServersCollectionView" HeightRequest="58" SelectionMode="None">
                                    <CollectionView.EmptyView>
                                        <Label Text="No pack MCP servers declared." TextColor="{StaticResource TextMuted}" FontSize="11" />
                                    </CollectionView.EmptyView>
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate>
                                            <Label Text="{Binding Name}" TextColor="{StaticResource TextSecondary}" FontSize="11" />
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Row="1" Stroke="{StaticResource Stroke}" StrokeThickness="1" BackgroundColor="{StaticResource Surface}" Padding="14">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="12">
                                <Label Text="Workspace files" TextColor="{StaticResource TextPrimary}" FontSize="17" FontAttributes="Bold" />
                                <CollectionView x:Name="FolderNodesCollectionView"
                                                HeightRequest="250"
                                                SelectionMode="Single"
                                                SelectionChanged="OnFolderNodeSelected">
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate>
                                            <Border Stroke="{StaticResource Stroke}" StrokeThickness="1" BackgroundColor="{StaticResource SurfaceAlt}" Padding="8" Margin="0,0,0,6">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="8" />
                                                </Border.StrokeShape>
                                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                    <VerticalStackLayout Spacing="1">
                                                        <Label Text="{Binding Label}" TextColor="{StaticResource TextPrimary}" FontSize="12" FontAttributes="Bold" />
                                                        <Label Text="{Binding Path}" TextColor="{StaticResource TextMuted}" FontSize="10" LineBreakMode="TailTruncation" />
                                                    </VerticalStackLayout>
                                                    <Label Grid.Column="1" Text="{Binding Status}" TextColor="{StaticResource Accent}" FontSize="10" VerticalOptions="Center" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                </Grid>
        </Grid>
    </Grid>
</ContentPage>



