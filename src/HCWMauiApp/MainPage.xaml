<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AgenticWorkspaceManager.MainPage"
             BackgroundColor="#0F172A">
    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20" MaximumWidthRequest="700" HorizontalOptions="CenterAndExpand">
            
            <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                <Label Text="👷‍♂️👼" FontSize="64" HorizontalOptions="Center" />
                <Label Text="AGENTIC AI WORKSPACE" FontSize="24" FontAttributes="Bold" TextColor="#38BDF8" HorizontalOptions="Center"/>
                <Label Text="Cross-platform control plane operational." TextColor="#94A3B8" HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <Border Stroke="#334155" StrokeThickness="1" HorizontalOptions="FillAndExpand" />

            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                <Button Grid.Column="0" Text="1. Scan Workspace" Clicked="OnScanWorkspaceClicked" BackgroundColor="#0EA5E9" TextColor="White" FontAttributes="Bold" />
                <Button Grid.Column="1" Text="2. Import Pack (.zip)" Clicked="OnImportPackClicked" BackgroundColor="#8B5CF6" TextColor="White" FontAttributes="Bold" />
                <Button Grid.Column="2" Text="3. System Check" Clicked="OnSystemCheckClicked" BackgroundColor="#F59E0B" TextColor="White" FontAttributes="Bold" />
            </Grid>

            <VerticalStackLayout Spacing="10">
                <Label Text="Available Agent Packs:" FontSize="16" FontAttributes="Bold" TextColor="#F1F5F9"/>
                <Border Stroke="#334155" StrokeThickness="1" BackgroundColor="#1E293B" Padding="5">
                    <CollectionView x:Name="AgentsCollectionView" HeightRequest="200">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="10" ColumnDefinitions="Auto,*">
                                    <CheckBox IsChecked="{Binding IsSelected}" Color="#38BDF8" VerticalOptions="Center"/>
                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Padding="10,0,0,0">
                                        <Label Text="{Binding FriendlyName}" FontAttributes="Bold" TextColor="#F8FAFC" FontSize="14"/>
                                        <Label Text="{Binding DirectoryName}" FontSize="11" TextColor="#64748B"/>
                                    </VerticalStackLayout>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Border>
            </VerticalStackLayout>

            <Border Stroke="#334155" StrokeThickness="1" BackgroundColor="#1E293B" Padding="15" Margin="0,10,0,10">
                <HorizontalStackLayout Spacing="15" VerticalOptions="Center">
                    <Switch x:Name="TokenomicsSwitch" IsToggled="True" OnColor="#22C55E" ThumbColor="#F8FAFC" />
                    <VerticalStackLayout VerticalOptions="Center">
                        <Label Text="Enable Agentic Tokenomics" FontAttributes="Bold" TextColor="#F8FAFC" FontSize="14"/>
                        <Label Text="Injects the Token Squeezer MCP and KV caching directives into VS Code." FontSize="11" TextColor="#94A3B8"/>
                    </VerticalStackLayout>
                </HorizontalStackLayout>
            </Border>

            <Border Stroke="#334155" StrokeThickness="1" BackgroundColor="#1E293B" Padding="15" Margin="0,0,0,10">
                <HorizontalStackLayout Spacing="15" VerticalOptions="Center">
                    <Switch x:Name="DryRunSwitch" IsToggled="False" OnColor="#F59E0B" ThumbColor="#F8FAFC" />
                    <VerticalStackLayout VerticalOptions="Center">
                        <Label Text="Dry-Run Activation" FontAttributes="Bold" TextColor="#F8FAFC" FontSize="14"/>
                        <Label Text="Previews merge, preflight, and sync actions without writing files or installing tools." FontSize="11" TextColor="#94A3B8"/>
                    </VerticalStackLayout>
                </HorizontalStackLayout>
            </Border>

            <Button Text="Orchestrate Selected Team to Workspace" Clicked="OnAssembleTeamClicked" BackgroundColor="#22C55E" TextColor="White" FontAttributes="Bold" HeightRequest="50"/>

            <Label Text="Execution Console:" FontSize="14" FontAttributes="Bold" TextColor="#94A3B8"/>
            <Editor x:Name="ConsoleOutput" IsReadOnly="True" HeightRequest="150" BackgroundColor="#020617" TextColor="#34D399" FontFamily="Consolas" FontSize="12" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>